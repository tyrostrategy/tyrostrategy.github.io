      "actionDef": "A specific and measurable task step linked to a project. Each action has an owner and a target date.",
      "kpi": "KPI (Key Performance Indicator)",
      "kpiDef": "A metric that measures the extent to which strategic objectives are being achieved.",
      "okr": "OKR (Objectives & Key Results)",
      "okrDef": "A management framework where objectives are defined with measurable key results.",
      "bsc": "BSC (Balanced Scorecard)",
      "bscDef": "A strategic management tool that balances financial and non-financial metrics.",
      "gantt": "Gantt Chart",
      "ganttDef": "A chart that visually plans projects and actions on a timeline.",
      "wbs": "WBS (Work Breakdown Structure)",
      "wbsDef": "A hierarchical decomposition of projects into their sub-components.",
      "sso": "SSO (Single Sign-On)",
      "ssoDef": "A method of signing in once with a corporate Microsoft account.",
      "rbac": "RBAC (Role-Based Access Control)",
